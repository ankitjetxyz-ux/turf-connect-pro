# Server
PORT=5000
NODE_ENV=production

# Supabase — copy from Dashboard → Settings → API
# IMPORTANT: use Project URL (https://xxx.supabase.co), NOT the Postgres connection string
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-public-key
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# Auth
JWT_SECRET=long-random-string
JWT_REFRESH_SECRET=another-long-random-string

# CORS (comma-separated production frontends)
FRONTEND_URL=https://bookmyturf.xyz,https://www.bookmyturf.xyz,https://admin.bookmyturf.xyz

# Email (OTP + contact form)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=bookmyturfofficial@gmail.com
SMTP_PASS=your-gmail-app-password
