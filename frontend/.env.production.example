# Set these in Vercel → Settings → Environment Variables (Production)
VITE_API_URL=https://api.bookmyturf.xyz/api
VITE_BACKEND_URL=https://api.bookmyturf.xyz

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: https://bookmyturf.xyz, https://www.bookmyturf.xyz, http://localhost:5173
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
